---
import SEO from "./SEO.astro";
import { MAIN_SITE_URL } from "../lib/movies.js";
import "../styles/global.css";

const { title, description, image, path, type, keywords, jsonLd, noindex } = Astro.props;
---

<!doctype html>
<html lang="he" dir="rtl">
<head>
  <SEO
    title={title}
    description={description}
    image={image}
    path={path}
    type={type}
    keywords={keywords}
    jsonLd={jsonLd}
    noindex={noindex}
  />
</head>
<body>
  <header class="site-header">
    <div class="container bar">
      <a href="/" class="brand">Zovex Catalog</a>
    </div>
  </header>

  <main class="container">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>Zovex Catalog &mdash; מאגר מידע על סרטים, סדרות ואנימה. לצפייה בפועל: <a href={MAIN_SITE_URL}>ZOVEX</a>.</p>
    </div>
  </footer>
</body>
</html>
