---
import Layout from "../components/Layout.astro";
import { getCatalog, MAIN_SITE_URL } from "../lib/movies.js";

export async function getStaticPaths() {
  const catalog = await getCatalog();
  return catalog.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "";
const path = `/${item.slug}/`;
const watchUrl = `${MAIN_SITE_URL.replace(/\/$/, "")}/${item.slug}`;

const title = `${item.title}${item.year ? ` (${item.year})` : ""} — צפייה ישירה | ZOVEX`;
const description = item.description
  ? item.description.slice(0, 155)
  : `צפייה ישירה ב${item.title} - פוסטר, תקציר, קטגוריה ושנת יציאה.`;

const schemaType = item.isSeries ? "TVSeries" : "Movie";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": schemaType,
    name: item.title,
    description: item.description || undefined,
    image: item.poster || undefined,
    datePublished: item.year ? String(item.year) : undefined,
    genre: item.category || undefined,
    ...(item.isSeries && item.seasonCount ? { numberOfSeasons: item.seasonCount } : {}),
    ...(item.isSeries && item.episodeCount ? { numberOfEpisodes: item.episodeCount } : {}),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ZOVEX", item: siteUrl + "/" },
      { "@type": "ListItem", position: 2, name: item.category || "קטלוג", item: siteUrl + "/" },
      { "@type": "ListItem", position: 3, name: item.title, item: siteUrl + path },
    ],
  },
];
---

<Layout
  title={title}
  description={description}
  image={item.poster}
  path={path}
  type={item.isSeries ? "video.tv_series" : "video.movie"}
  keywords={[item.title, item.category, "צפייה ישירה", "ZOVEX"].filter(Boolean)}
  jsonLd={jsonLd}
>
  <nav class="breadcrumbs" aria-label="breadcrumb">
    <a href="/">ZOVEX</a> / <span>{item.category || "קטגוריה"}</span> / <span>{item.title}</span>
  </nav>

  <section class="detail-hero">
    {item.poster && <div class="bg-blur" style={`background-image:url(${item.poster})`}></div>}
    <div class="bg-fade"></div>

    <div class="detail-content">
      <div class="poster-col">
        {item.poster && <img src={item.poster} alt={item.title} width="400" height="600" loading="eager" />}
      </div>
      <div class="info-col">
        <div class="badge-row">
          {item.category && <span class="badge">{item.category}</span>}
          {item.year && <span class="badge">{item.year}</span>}
          {item.isSeries && item.seasonCount && (
            <span class="badge">{item.seasonCount} עונות</span>
          )}
          {item.isSeries && item.episodeCount && (
            <span class="badge">{item.episodeCount} פרקים</span>
          )}
        </div>

        <h1>{item.title}</h1>

        {item.description && <p class="description">{item.description}</p>}

        <a class="watch-btn" href={watchUrl} rel="noopener">
          ▶ צפה עכשיו ב-ZOVEX
        </a>
        <span class="watch-hint">הצפייה בפועל מתבצעת באתר ZOVEX הראשי.</span>
      </div>
    </div>

    {item.isSeries && item.episodes?.length > 0 && (
      <div class="episodes-section">
        {Array.from(new Set(item.episodes.map((e) => e.season))).map((season) => (
          <div class="season-group">
            <h2 class="season-title">עונה {season}</h2>
            <ul class="episode-list">
              {item.episodes
                .filter((e) => e.season === season)
                .map((ep) => (
                  <li>
                    <a class="episode-row" href={watchUrl} rel="noopener">
                      <span class="episode-num">פרק {ep.episode}</span>
                      {ep.title && <span class="episode-title">{ep.title}</span>}
                    </a>
                  </li>
                ))}
            </ul>
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>
