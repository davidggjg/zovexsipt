---
import Layout from "../components/Layout.astro";
import MovieCard from "../components/MovieCard.astro";
import { getCatalog, getCategories, getLiveChannels, MAIN_SITE_URL } from "../lib/movies.js";

const catalog = await getCatalog();
const categories = getCategories(catalog);
const liveChannels = await getLiveChannels();

// The homepage used to server-render every single catalog item (300+) at
// once, relying on client JS to hide the rest with display:none - but the
// images (300+ <img> tags, all already in the initial DOM) still got
// evaluated/loaded far more eagerly than intended, making first load very
// heavy. Now only the first page is real server-rendered HTML (fast paint,
// works with no JS); everything else is a small JSON payload the client
// script turns into DOM nodes on demand (scroll/search/filter), so the
// browser only ever fetches images for cards that actually get shown.
const PAGE_SIZE = 40;
const firstPage = catalog.slice(0, PAGE_SIZE);
const catalogLite = catalog.map((item) => ({
  slug: item.slug,
  title: item.title,
  poster: item.poster || "",
  category: item.category || "",
  year: item.year || "",
}));

const title = "ZOVEX — צפייה ישירה בסרטים, סדרות ואנימה";
const description = `ZOVEX - צפייה ישירה בסרטים, סדרות ואנימה בחינם. חיפוש וסינון לפי קטגוריה.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: Astro.site?.toString(),
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: catalog.slice(0, 200).map((item, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `${Astro.site?.toString().replace(/\/$/, "")}/${item.slug}`,
      name: item.title,
    })),
  },
];
---

<Layout title={title} description={description} path="/" jsonLd={jsonLd} keywords={["סרטים", "סדרות", "אנימה", "צפייה ישירה", "ZOVEX"]}>
  <section class="hero">
    <h1>ZOVEX</h1>
    <p>צפייה ישירה בסרטים, סדרות ואנימה בחינם &mdash; חפשו והתחילו לצפות.</p>
  </section>

  {liveChannels.length > 0 && (
    <section class="live-section">
      <div class="live-heading">
        <span class="live-pulse-dot"></span>
        <h2>שידורים חיים עכשיו</h2>
      </div>
      <div class="live-row">
        {liveChannels.map((ch) => (
          <a class="live-card" href={`${MAIN_SITE_URL.replace(/\/$/, "")}/live/${ch.slug}`} rel="noopener">
            <div class="live-poster-wrap">
              {ch.poster && <img src={ch.poster} alt={ch.title} loading="lazy" decoding="async" />}
              <span class="live-badge">LIVE</span>
            </div>
            <p class="live-title">{ch.title}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="search-box" style="margin: 0 auto 8px; max-width: 480px;">
    <input id="search" type="search" placeholder="חיפוש לפי שם..." autocomplete="off" />
  </div>

  <div class="filters" id="filters" style="justify-content: center;">
    <button class="chip active" data-cat="all">הכל</button>
    {categories.map((cat) => (
      <button class="chip" data-cat={cat}>{cat}</button>
    ))}
  </div>

  <div class="grid" id="grid">
    {firstPage.map((item) => (
      <div class="grid-item">
        <MovieCard item={item} />
      </div>
    ))}
  </div>

  <p class="empty-state" id="empty" style="display:none;">לא נמצאו תוצאות תואמות.</p>
  <div class="sentinel" id="sentinel"></div>
</Layout>

<script define:vars={{ catalogData: catalogLite, PAGE_SIZE }}>
  const grid = document.getElementById("grid");
  const searchInput = document.getElementById("search");
  const filterBtns = document.querySelectorAll("#filters .chip");
  const emptyState = document.getElementById("empty");
  const sentinel = document.getElementById("sentinel");

  let activeCategory = "all";
  let query = "";
  let visibleCount = PAGE_SIZE;

  function matches(item) {
    const t = (item.title || "").toLowerCase();
    const okCat = activeCategory === "all" || item.category === activeCategory;
    const okQuery = !query || t.includes(query);
    return okCat && okQuery;
  }

  function cardHtml(item) {
    const meta = [item.category, item.year].filter(Boolean).join(" · ");
    const img = item.poster
      ? `<img src="${item.poster}" alt="${item.title}" loading="lazy" decoding="async" width="300" height="450" />`
      : "";
    return `<div class="grid-item"><a class="card" href="/${item.slug}" data-title="${item.title}" data-category="${item.category}">
      <div class="poster-wrap">${img}</div>
      <div class="info"><p class="title">${item.title}</p><p class="meta">${meta}</p></div>
    </a></div>`;
  }

  function render() {
    const isDefaultView = activeCategory === "all" && !query;
    // Default view with nothing scrolled yet: keep the server-rendered
    // first page exactly as-is (real HTML, no JS needed, fastest possible
    // paint) - don't touch the DOM at all.
    if (isDefaultView && visibleCount <= PAGE_SIZE) {
      emptyState.style.display = "none";
      return;
    }
    const filtered = catalogData.filter(matches);
    grid.innerHTML = filtered.slice(0, visibleCount).map(cardHtml).join("");
    emptyState.style.display = filtered.length === 0 ? "block" : "none";
  }

  searchInput.addEventListener("input", (e) => {
    query = e.target.value.trim().toLowerCase();
    visibleCount = PAGE_SIZE;
    render();
  });

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeCategory = btn.dataset.cat;
      visibleCount = PAGE_SIZE;
      render();
    });
  });

  const observer = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        visibleCount += PAGE_SIZE;
        render();
      }
    },
    { rootMargin: "400px" }
  );
  observer.observe(sentinel);
</script>
